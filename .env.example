# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
# IMPORTANT: Set a strong `SECRET_KEY` in production. Example (generate locally):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then set the value in your deployment environment (do NOT commit secrets to git).
# Example:
SECRET_KEY=your-production-secret-here

# Email Configuration (Gmail)
# For Gmail: Use App Passwords - https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_SUPPRESS_SEND=False

# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-secure-password
ADMIN_EMAIL=your-email@gmail.com

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_FLYER_BUCKET=event-flyers
SUPABASE_LOGO_BUCKET=sponsor-logos
SUPABASE_POST_BUCKET=post-images
SUPABASE_GALLERY_BUCKET=post-images

# Optional: For other email providers
# Outlook/Hotmail
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587

# Yahoo
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=587
