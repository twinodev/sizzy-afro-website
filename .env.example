# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
# IMPORTANT: Set a strong `SECRET_KEY` in production. Example (generate locally):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then set the value in your deployment environment (do NOT commit secrets to git).
# Example:
SECRET_KEY=your-production-secret-here

# Email Configuration (Brevo API)
# For Brevo: Use the API key from your Brevo dashboard.
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Dance with Sizzy Afro

# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-secure-password
ADMIN_EMAIL=your-email@gmail.com

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_FLYER_BUCKET=event-flyers
SUPABASE_LOGO_BUCKET=sponsor-logos
SUPABASE_POST_BUCKET=post-images
SUPABASE_GALLERY_BUCKET=post-images

